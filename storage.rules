rules_version = '2';
// Deploy: Firebase Console → Build → Storage → Rules → Publish
// (or `firebase deploy --only storage` if this file is wired in firebase.json)

service firebase.storage {
  match /b/{bucket}/o {
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
