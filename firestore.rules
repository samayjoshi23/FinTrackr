rules_version = '2';
// Deploy: `firebase deploy --only firestore`
//
// Collections covered:
//   users (+ notifications, devices), accounts, transactions, recurring-transactions,
//   budgets, goals, categories, monthlyReports
// Cloud Functions use the Admin SDK and bypass these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Account access supports owner and accepted active members.
    function canAccessAccount(accountId) {
      let account = get(/databases/$(database)/documents/accounts/$(accountId)).data;
      return isSignedIn() && (
        accountId == request.auth.uid ||
        account.ownerId == request.auth.uid ||
        (account.activeMemberIds is list && account.activeMemberIds.hasAny([request.auth.uid]))
      );
    }

    function canAccessExistingAccount() {
      return isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (resource.data.activeMemberIds is list && resource.data.activeMemberIds.hasAny([request.auth.uid]))
      );
    }

    function isAccountOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── User profile & subcollections ───────────────────────────────────────
    match /users/{userId} {
      // Public read for invite / directory search from local devices.
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Notifications: created by Cloud Functions only; client may read / update status / delete.
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn()
          && request.auth.uid == userId
          && onlyUpdatingAllowedFields(['status', 'readAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /devices/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Written only by scheduled functions (idempotency markers). No client access.
      match /cron-markers/{markerId} {
        allow read, write: if false;
      }
    }

    // ─── Accounts ────────────────────────────────────────────────────────────
    match /accounts/{accountId} {
      allow read: if canAccessExistingAccount() || accountId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAccountOwner() || (
        canAccessExistingAccount() &&
        onlyUpdatingAllowedFields(['isSelected', 'isActive', 'updatedAt'])
      );
      allow delete: if isAccountOwner() || accountId == request.auth.uid;
    }

    // ─── Transactions (scoped by accountId; no ownerId field on document) ────
    match /transactions/{transactionId} {
      allow read: if canAccessAccount(resource.data.accountId);
      allow create: if canAccessAccount(request.resource.data.accountId);
      allow update, delete: if canAccessAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
    }

    // ─── Recurring transactions (same account scoping as transactions) ───────
    match /recurring-transactions/{recurringId} {
      allow read: if canAccessAccount(resource.data.accountId);
      allow create: if canAccessAccount(request.resource.data.accountId);
      allow update, delete: if canAccessAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
    }

    // ─── Monthly reports (monthlyReports — keyed by accountId in app queries) ─
    match /monthlyReports/{reportId} {
      allow read: if canAccessAccount(resource.data.accountId);
      allow create: if canAccessAccount(request.resource.data.accountId);
      allow update, delete: if canAccessAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
    }

    // ─── Budgets / goals / categories (account-scoped) ──────────────────────
    match /budgets/{budgetId} {
      allow read: if canAccessAccount(resource.data.accountId);
      allow create: if canAccessAccount(request.resource.data.accountId);
      allow update: if canAccessAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
      allow delete: if canAccessAccount(resource.data.accountId);
    }

    match /goals/{goalId} {
      allow read: if canAccessAccount(resource.data.accountId);
      allow create: if canAccessAccount(request.resource.data.accountId);
      allow update: if canAccessAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
      allow delete: if canAccessAccount(resource.data.accountId);
    }

    match /categories/{categoryId} {
      allow read: if canAccessAccount(resource.data.accountId);
      allow create: if canAccessAccount(request.resource.data.accountId);
      allow update: if canAccessAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
      allow delete: if canAccessAccount(resource.data.accountId);
    }

    // ─── Groups ───────────────────────────────────────────────────────────────
    function canReadGroupData(groupData) {
      return isSignedIn() && (
        groupData.creatorId == request.auth.uid ||
        (groupData.memberIds is list && groupData.memberIds.hasAny([request.auth.uid]))
      );
    }

    function isGroupMember(groupId) {
      let groupData = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return isSignedIn() && (
        groupData.creatorId == request.auth.uid ||
        (groupData.activeMemberIds is list && groupData.activeMemberIds.hasAny([request.auth.uid]))
      );
    }

    function isGroupCreator(groupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/groups/$(groupId)).data.creatorId == request.auth.uid;
    }

    match /groups/{groupId} {
      // Temporary compatibility: legacy group docs may not yet have memberIds.
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isGroupMember(groupId)
      );
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      match /expenses/{expenseId} {
        allow read: if isSignedIn();
        allow write: if isGroupCreator(groupId) || isGroupMember(groupId);
      }

      match /settlements/{settlementId} {
        allow read: if isSignedIn();
        allow write: if isGroupCreator(groupId) || isGroupMember(groupId);
      }
    }

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function onlyUpdatingAllowedFields(allowed) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowed);
    }
  }
}
