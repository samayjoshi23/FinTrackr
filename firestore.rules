rules_version = '2';
// Deploy: `firebase deploy --only firestore`
//
// Collections covered:
//   users (+ notifications, devices), accounts, transactions, recurring-transactions,
//   budgets, goals, categories, monthlyReports
// Cloud Functions use the Admin SDK and bypass these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Primary account uses doc id == owner uid; additional accounts use auto ids with ownerId.
    function ownsAccount(accountId) {
      return isSignedIn() && (
        accountId == request.auth.uid ||
        get(/databases/$(database)/documents/accounts/$(accountId)).data.ownerId == request.auth.uid
      );
    }

    function ownerIdMatchesExisting() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function ownerIdMatchesOnCreate() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function ownerIdUnchangedOnUpdate() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    // ─── User profile & subcollections ───────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Notifications: created by Cloud Functions only; client may read / update status / delete.
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn()
          && request.auth.uid == userId
          && onlyUpdatingAllowedFields(['status', 'readAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /devices/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Written only by scheduled functions (idempotency markers). No client access.
      match /cron-markers/{markerId} {
        allow read, write: if false;
      }
    }

    // ─── Accounts ────────────────────────────────────────────────────────────
    match /accounts/{accountId} {
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || accountId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || accountId == request.auth.uid
      );
    }

    // ─── Transactions (scoped by accountId; no ownerId field on document) ────
    match /transactions/{transactionId} {
      allow read: if ownsAccount(resource.data.accountId);
      allow create: if ownsAccount(request.resource.data.accountId);
      allow update, delete: if ownsAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
    }

    // ─── Recurring transactions (same account scoping as transactions) ───────
    match /recurring-transactions/{recurringId} {
      allow read: if ownsAccount(resource.data.accountId);
      allow create: if ownsAccount(request.resource.data.accountId);
      allow update, delete: if ownsAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
    }

    // ─── Monthly reports (monthlyReports — keyed by accountId in app queries) ─
    match /monthlyReports/{reportId} {
      allow read: if ownsAccount(resource.data.accountId);
      allow create: if ownsAccount(request.resource.data.accountId);
      allow update, delete: if ownsAccount(resource.data.accountId)
        && request.resource.data.accountId == resource.data.accountId;
    }

    // ─── Budgets / goals / categories (ownerId on document) ─────────────────
    match /budgets/{budgetId} {
      allow read: if ownerIdMatchesExisting();
      allow create: if ownerIdMatchesOnCreate();
      allow update: if ownerIdMatchesExisting() && ownerIdUnchangedOnUpdate();
      allow delete: if ownerIdMatchesExisting();
    }

    match /goals/{goalId} {
      allow read: if ownerIdMatchesExisting();
      allow create: if ownerIdMatchesOnCreate();
      allow update: if ownerIdMatchesExisting() && ownerIdUnchangedOnUpdate();
      allow delete: if ownerIdMatchesExisting();
    }

    match /categories/{categoryId} {
      allow read: if ownerIdMatchesExisting();
      allow create: if ownerIdMatchesOnCreate();
      allow update: if ownerIdMatchesExisting() && ownerIdUnchangedOnUpdate();
      allow delete: if ownerIdMatchesExisting();
    }

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function onlyUpdatingAllowedFields(allowed) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowed);
    }
  }
}
