rules_version = '2';
// Deploy: Firebase Console → Firestore → Rules, or `firebase deploy --only firestore`

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profile ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Notifications are user-scoped; only the owner can read/write them.
      // Cloud Functions use the Admin SDK (bypasses these rules).
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Only the receiver can mark notifications as read / action-taken.
        // Creation is done exclusively by Cloud Functions (Admin SDK).
        allow update: if request.auth != null
          && request.auth.uid == userId
          && onlyUpdatingAllowedFields(['status', 'readAt']);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Device tokens — read/write by owner only.
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Accounts ────────────────────────────────────────────────────────────
    match /accounts/{accountId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || accountId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || accountId == request.auth.uid
      );
    }

    // ─── Budgets ─────────────────────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // ─── Goals ───────────────────────────────────────────────────────────────
    match /goals/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // ─── Transactions ────────────────────────────────────────────────────────
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // ─── Categories ──────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function onlyUpdatingAllowedFields(allowed) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowed);
    }
  }
}
